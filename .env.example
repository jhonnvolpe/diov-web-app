# DIOV Environment Variables
# Copy this to .env and fill in your values

# API URL — your diov-api Render service URL
VITE_API_URL=https://diov-api.onrender.com/api/trpc

# For local development (uses the Hono dev server)
# VITE_API_URL=/api/trpc

# Database URL — your diov-db PostgreSQL connection string
DATABASE_URL=postgresql://username:password@host:port/database
